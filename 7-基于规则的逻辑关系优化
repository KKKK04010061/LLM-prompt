LLM_REL_XLSX   = r"D:/刘kk/第七章-2条学科交叉科学问题/2-基于大模型的模块逻辑关系分析结果.xlsx"
REL_TYPES_XLSX = r"D:/刘kk/第七章-2条学科交叉科学问题/逻辑关系类型.xlsx"
OUT_XLSX       = r"D:/刘kk/第七章-2条学科交叉科学问题/2-基于规则推理的模块逻辑关系优化结果.xlsx"

